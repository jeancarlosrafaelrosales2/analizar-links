# ============================================================
# analizar-links — Environment Variables
# ============================================================
# Copia este archivo a .env y ajusta los valores.
# NUNCA commitear .env con valores reales.

# ── Server ──────────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0

# ── CORS ────────────────────────────────────────────────────
# Dev: use * for any origin. Production: comma-separated whitelist
CORS_ALLOWED_ORIGINS=*
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ── Redis (opcional — si no se setea, usa caché en memoria) ─
# REDIS_URL=redis://localhost:6379

# ── Storage ─────────────────────────────────────────────────
STORAGE_PATH=/tmp/analizar-links
# S3 (futuro):
# AWS_S3_BUCKET=analizar-links-audio
# AWS_REGION=us-east-1

# ── yt-dlp path (si no está en PATH) ────────────────────────
# YTDLP_PATH=/usr/local/bin/yt-dlp

# ── ffmpeg path (si no está en PATH) ────────────────────────
# FFMPEG_PATH=/usr/bin/ffmpeg

# ── Job TTL (segundos antes de expirar el cache de un job) ──
JOB_TTL_SECONDS=3600

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_RPS=10

# ── Log Level ───────────────────────────────────────────────
RUST_LOG=analizar_links=debug,tower_http=debug
